// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          String    @default("PARTY") // PARTY, ARBITRATOR, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  filedCases    Case[]    @relation("ClaimantCases")
  defendedCases Case[]    @relation("RespondentCases")
  documents     Document[]
  auditLogs     AuditLog[]
}

model Case {
  id            String    @id @default(cuid())
  title         String
  description   String
  // FILED, AWAITING_RESPONSE, AWAITING_VERDICT, IN_MEDIATION, AWAITING_EVIDENCE,
  // AI_REVIEWED, ESCALATED, ESCALATED_TO_HUMAN, RESOLVED, RESOLVED_BY_SETTLEMENT
  status        String    @default("DRAFT")
  claimantId    String
  respondentId  String?
  respondentDescription String?
  analysis      String?   // JSON storing normalized arguments
  disputeType   String?   // set by the triage node (refund, contract-breach, ...)
  complexity    String?   // low | medium | high, set by the triage node
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  claimant      User      @relation("ClaimantCases", fields: [claimantId], references: [id])
  respondent    User?     @relation("RespondentCases", fields: [respondentId], references: [id])
  documents     Document[]
  verdicts      Verdict[]
  auditLogs     AuditLog[]
  settlements       Settlement[]
  evidenceRequests  EvidenceRequest[]
}

model Document {
  id            String    @id @default(cuid())
  url           String
  type          String    // EVIDENCE, CLAIM, RESPONSE
  caseId        String
  uploaderId    String
  createdAt     DateTime  @default(now())

  case          Case      @relation(fields: [caseId], references: [id])
  uploader      User      @relation(fields: [uploaderId], references: [id])
}

model Verdict {
  id            String    @id @default(cuid())
  caseId        String
  content       String
  reasoning     String?
  citations     String?   // JSON array of strings
  aiConfidence  Float?
  passedBiasCheck    Boolean?
  biasCheckReasoning String?
  revisionCount      Int?     @default(0)
  isHuman       Boolean   @default(false)
  createdAt     DateTime  @default(now())

  case          Case      @relation(fields: [caseId], references: [id])
}

model Settlement {
  id                  String   @id @default(cuid())
  caseId              String
  proposal            String
  terms               String   // JSON array of strings
  claimantResponse    String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  respondentResponse  String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt           DateTime @default(now())

  case                Case     @relation(fields: [caseId], references: [id])
}

model EvidenceRequest {
  id          String   @id @default(cuid())
  caseId      String
  targetParty String   // CLAIMANT | RESPONDENT
  question    String
  status      String   @default("PENDING") // PENDING | FULFILLED
  createdAt   DateTime @default(now())

  case        Case     @relation(fields: [caseId], references: [id])
}

model AuditLog {
  id            String    @id @default(cuid())
  action        String
  userId        String?
  caseId        String?
  details       String?
  timestamp     DateTime  @default(now())

  user          User?     @relation(fields: [userId], references: [id])
  case          Case?     @relation(fields: [caseId], references: [id])
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "ai_config"
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}
